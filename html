<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mapa Conceitual Interativo</title>
    <style>
        :root {
            --bg-color: #f4f7f6;
            --line-color: #b2bec3;
            --primary-node: #6c5ce7;
            --secondary-node: #00cec9;
            --tertiary-node: #fab1a0;
            --text-light: #ffffff;
            --text-dark: #2d3436;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            margin: 0;
            padding: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h1 {
            color: var(--text-dark);
            margin-bottom: 30px;
        }

        /* Estrutura do Mapa */
        .map-container {
            display: flex;
            justify-content: center;
            width: 100%;
        }

        .tree ul {
            padding-top: 20px; 
            position: relative;
            transition: all 0.5s;
            display: flex;
            justify-content: center;
        }

        .tree li {
            float: left; 
            text-align: center;
            list-style-type: none;
            position: relative;
            padding: 20px 10px 0 10px;
            transition: all 0.5s;
        }

        /* Conectores lineares */
        .tree li::before, .tree li::after {
            content: '';
            position: absolute; 
            top: 0; 
            right: 50%;
            border-top: 2px solid var(--line-color);
            width: 50%; 
            height: 20px;
        }
        .tree li::after {
            right: auto; 
            left: 50%;
            border-left: 2px solid var(--line-color);
        }

        /* Removendo conectores das pontas */
        .tree li:only-child::after, .tree li:only-child::before {
            display: none;
        }
        .tree li:only-child { 
            padding-top: 0;
        }
        .tree li:first-child::before, .tree li:last-child::after {
            border: 0 none;
        }
        .tree li:last-child::before {
            border-right: 2px solid var(--line-color);
            border-radius: 0 5px 0 0;
        }
        .tree li:first-child::after {
            border-radius: 5px 0 0 0;
        }

        /* Linhas descendentes dos pais */
        .tree ul ul::before {
            content: '';
            position: absolute; 
            top: 0; 
            left: 50%;
            border-left: 2px solid var(--line-color);
            width: 0; 
            height: 20px;
        }

        /* Estilização dos Nós (Caixas) */
        .node {
            border: 2px solid transparent;
            padding: 15px 20px;
            text-decoration: none;
            color: var(--text-light);
            font-size: 14px;
            font-weight: bold;
            display: inline-block;
            border-radius: 8px;
            transition: all 0.3s;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            max-width: 150px;
        }

        /* Cores por Nível */
        .level-1 { background-color: var(--primary-node); }
        .level-2 { background-color: var(--secondary-node); color: var(--text-dark); }
        .level-3 { background-color: var(--tertiary-node); color: var(--text-dark); }

        /* Efeito Hover e Interatividade */
        .node:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.2);
        }

        .node:active {
            transform: translateY(-2px);
        }
    </style>
</head>
<body>

    <h1>Mapa Conceitual: Desenvolvimento Web</h1>

    <div class="map-container">
        <div class="tree">
            <ul>
                <li>
                    <div class="node level-1" onclick="alert('Conceito Principal: O ecossistema do desenvolvimento web moderno.')">Dev Web Frontend</div>
                    <ul>
                        <li>
                            <div class="node level-2" onclick="alert('Estrutura: Responsável pelo esqueleto e conteúdo da página.')">HTML</div>
                            <ul>
                                <li>
                                    <div class="node level-3">Tags</div>
                                </li>
                                <li>
                                    <div class="node level-3">Semântica</div>
                                </li>
                            </ul>
                        </li>
                        <li>
                            <div class="node level-2" onclick="alert('Estilo: Responsável pelo design, layout e animações.')">CSS</div>
                            <ul>
                                <li>
                                    <div class="node level-3">Flexbox / Grid</div>
                                </li>
                                <li>
                                    <div class="node level-3">Responsividade</div>
                                </li>
                            </ul>
                        </li>
                        <li>
                            <div class="node level-2" onclick="alert('Dinamismo: Responsável pela lógica e interatividade do usuário.')">JavaScript</div>
                            <ul>
                                <li>
                                    <div class="node level-3">Manipulação do DOM</div>
                                </li>
                                <li>
                                    <div class="node level-3">APIs</div>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>

</body>
</html>
